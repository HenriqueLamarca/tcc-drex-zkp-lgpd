{
  "name": "drex-zkp-lgpd-poc",
  "version": "0.1.0",
  "description": "PoC: ZKP + Smart Contracts para conformidade LGPD no DREX (Hyperledger Besu + ZoKrates + Groth16)",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/**/*.spec.ts",
    "test:integration": "hardhat test test/integration/**/*.spec.ts",
    "coverage": "hardhat coverage",
    "deploy": "hardhat run scripts/04_deploy.ts --network besu",
    "deploy:local": "hardhat run scripts/04_deploy.ts --network hardhat",
    "dvp:demo": "hardhat run scripts/05_run_dvp_demo.ts --network besu",
    "dvp:demo:local": "hardhat run scripts/05_run_dvp_demo.ts --network hardhat",
    "dvp:demo:fail": "hardhat run scripts/06_run_dvp_demo_fail.ts --network besu",
    "dvp:demo:fail:local": "hardhat run scripts/06_run_dvp_demo_fail.ts --network hardhat",
    "benchmark": "hardhat run benchmark/benchmark.ts --network hardhat",
    "viz": "node viz/server.cjs",
    "lint:sol": "solhint contracts/**/*.sol",
    "lint:ts": "eslint scripts test benchmark hardhat.config.ts --ext .ts",
    "lint": "npm run lint:sol && npm run lint:ts",
    "typecheck": "tsc --noEmit",
    "zkp:setup": "bash scripts/01_setup_zkp.sh"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "chai": "^4.3.0",
    "eslint": "^8.57.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.0",
    "solhint": "^5.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "eciesjs": "^0.5.0",
    "ethers": "^6.13.0"
  }
}
